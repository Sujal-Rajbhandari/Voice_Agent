# Copy to .env and fill in. The agent reads these on startup.

# --- Voice: Deepgram (STT Nova-3 + TTS Aura-2). console.deepgram.com
DEEPGRAM_API_KEY="your-deepgram-key"

# --- Brain: OpenAI (gpt-4o-mini). platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."

# --- Transport: LiveKit.  cloud.livekit.io -> Settings -> Keys
# Only needed for `python main.py dev` / the browser UI. `console` mode needs none.
WEBSOCKET_URL="wss://your-project.livekit.cloud"   # mapped to LIVEKIT_URL
LIVE_KIT="APIxxxxxxxx"                              # mapped to LIVEKIT_API_KEY
LIVEKIT_API_SECRET="your-livekit-secret"

# --- Auto-hangup tuning (seconds), optional
IDLE_AWAY_TIMEOUT="20"   # silence before the agent asks "are you still there?"
IDLE_GRACE="12"          # more silence after the warning before it hangs up
